# Server Configuration
SECRET_KEY=your_secret_key_here
JWT_SECRET_KEY=your_jwt_secret_key_here
FLASK_ENV=development
PORT=5000

# Database
DATABASE_URL=sqlite:///./medverify_dev.db

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
JWT_BLOCKLIST_REDIS_URL=redis://localhost:6379/0
JWT_BLOCKLIST_REQUIRED=false

# Optional development seed users
# MEDVERIFY_SEED_ADMIN_PASSWORD=
# MEDVERIFY_SEED_VERIFIER_PASSWORD=
# MEDVERIFY_SEED_VIEWER_PASSWORD=

# ML Model
# MODEL_PATH=./ml/models/classifier.pkl

# Frontend
VITE_API_URL=http://localhost:5000
